# Copy to .env (gitignored) and fill in. No secrets are committed.

# Stage A demos: Fiber node RPC endpoints (a merchant node and a buyer node).
MERCHANT_RPC=http://127.0.0.1:8237
BUYER_RPC=http://127.0.0.1:8227

# Stage B custody demo: path to a file holding a funded Pudge testnet private key (0x...).
CKB_DEPLOYER_KEY_FILE=

# Fiber node key encryption password (used when running your own fnn nodes, not by this repo).
FIBER_SECRET_KEY_PASSWORD=
